# ツールやAIの設定フォルダ
.claude/

# 巨大なインストーラーやISOファイルは除外
*.iso
*.exe
*.msi

# 特定のフォルダの中身をまるごと除外
/modules/standard/driver_config/driver/*
!/modules/standard/driver_config/driver/.gitkeep

/modules/standard/printer_driver_config/INF/*
!/modules/standard/printer_driver_config/INF/命名規則.txt
!/modules/standard/printer_driver_config/INF/.gitkeep

/evidence/export_history/*
!/evidence/export_history/.gitkeep

/evidence/gyotaku/*
!/evidence/gyotaku/.gitkeep

/logs/*
!/logs/.gitkeep

/logs/history/*
!/logs/history
!/logs/history/.gitkeep



# AppxBundle パッケージ（HEIF/HEVC拡張等）
*.AppxBundle

# バックアップファイル
*.bak

# 壁紙画像ファイル
/modules/standard/wallpaper_config/wallpaper/*
!/modules/standard/wallpaper_config/wallpaper/.gitkeep

# 一時ファイルやキャッシュ
*.tmp
*.log